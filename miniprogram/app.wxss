@import './styles/theme.wxss';

/** 全局样式 - 妈妈小助理|辅食计划（暖白底 + #7FB77E 主绿） */
page {
  height: 100%;
  background-color: var(--bg-warm);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 助理口吻文案样式 */
.tip-text {
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.5;
}

/* 底部固定按钮区域 */
.footer-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--card);
  box-shadow: 0 -2rpx 16rpx rgba(127, 183, 126, 0.09);
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, var(--green) 0%, var(--green-deep) 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
}

.btn-primary:active {
  opacity: 0.9;
}
