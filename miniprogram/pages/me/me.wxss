.container {
  padding-bottom: 60rpx;
}

.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx 0;
  margin-bottom: 24rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #eee;
  margin-right: 28rpx;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.menu-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item text:first-child {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-item .tip-text {
  flex: 1;
  margin-left: 16rpx;
  font-size: 24rpx;
  color: #8a978e;
}

.menu-item-switch {
  flex-wrap: wrap;
}
.menu-item-switch .tip-text {
  width: 100%;
  margin-left: 0;
  margin-top: 8rpx;
  order: 1;
}
.menu-item-switch switch {
  margin-left: auto;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

.footer-tip {
  margin-top: 48rpx;
  padding: 0 8rpx;
}
