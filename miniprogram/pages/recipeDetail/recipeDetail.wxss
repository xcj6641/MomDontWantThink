/* ========== 页面整体：内容区 + 底部固定栏留白 ========== */
.page {
  min-height: 100vh;
  background: #F6F8F7;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}
.page-content {
  padding: 24rpx 24rpx 32rpx;
}

/* ========== 卡片统一样式（统一白底，减少层级） ========== */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ========== 1. 菜谱信息主卡片：与其它卡片统一白底 ========== */
.recipe-hero {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
}
.recipe-hero-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.recipe-hero-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2A25;
  line-height: 1.3;
}
.recipe-hero-collect {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.recipe-hero-collect .collect-icon {
  width: 36rpx;
  height: 36rpx;
}
.recipe-hero-collect.animate .collect-icon {
  animation: collectPop 0.35s ease-out;
}
@keyframes collectPop {
  0% { transform: scale(0.9); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}
.recipe-hero-tags {
  display: block;
  margin-bottom: 12rpx;
}
.recipe-hero-tag {
  background: #EEF6F1;
  color: #5C9D6B;
  border-radius: 20rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  display: inline-block;
  margin-right: 12rpx;
  margin-bottom: 6rpx;
}
.recipe-hero-desc {
  font-size: 24rpx;
  color: #6E7F76;
  line-height: 1.6;
  display: block;
}

/* ========== 2. 备菜小提醒：标题 + 分组 + 列表（无灰色内嵌块） ========== */
.card-prep {
  /* 与 .card 一致，无需覆盖 */
}
.prep-main-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 18rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #EEF2F0;
}
.prep-main-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2F3A35;
}
.prep-group {
  margin-top: 20rpx;
}
.prep-group:first-of-type {
  margin-top: 0;
}
.prep-group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2F3A35;
  margin-bottom: 10rpx;
  display: block;
}
.prep-item {
  font-size: 26rpx;
  color: #5F6F66;
  line-height: 40rpx;
  margin-bottom: 6rpx;
  padding-left: 0;
}
.prep-item:last-child {
  margin-bottom: 0;
}

/* ========== 模块标题：食材 / 做法 / 小提示 ========== */
.card-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.card-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2F3A35;
}
.card-title-border {
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #EEF2F0;
}

/* ========== 3. 食材 ========== */
.ingredient-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: #5F6F66;
}
.ingredient-name {
  color: #4A7C59;
  font-weight: 500;
}
.ingredient-amount {
  color: #7B8B83;
  margin-left: 16rpx;
}

/* ========== 4. 做法 ========== */
.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}
.step-item:last-child {
  margin-bottom: 0;
}
.step-num {
  color: #5C9D6B;
  font-weight: 700;
  font-size: 28rpx;
  min-width: 40rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.step-content {
  font-size: 26rpx;
  color: #5F6F66;
  line-height: 42rpx;
  flex: 1;
}

/* ========== 小提示 ========== */
.tip-item {
  font-size: 26rpx;
  color: #5F6F66;
  line-height: 40rpx;
  margin-bottom: 8rpx;
  display: block;
}
.tip-item:last-child {
  margin-bottom: 0;
}

/* ========== 底部固定操作栏 ========== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 128rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #FFFFFF;
  border-top: 2rpx solid #EEF2F0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
/* 底部按钮：统一默认与激活规则 */
.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex: 1;
  background: transparent;
  font-size: 20rpx;
}
.bottom-btn-text {
  line-height: 1.2;
  color: #6F7F77;
}
.bottom-btn-icon {
  width: 36rpx;
  height: 36rpx;
  /* 默认 outline 色 */
  filter: brightness(0) saturate(100%) invert(72%) sepia(22%) saturate(800%) hue-rotate(110deg) brightness(92%) contrast(88%);
}
/* 收藏：激活 #F6B73C */
.bottom-btn.collect.active .bottom-btn-text { color: #F6B73C; }
.bottom-btn.collect.active .bottom-btn-icon {
  filter: brightness(0) saturate(100%) invert(82%) sepia(45%) saturate(1500%) hue-rotate(360deg) brightness(102%) contrast(95%);
}
.bottom-btn.collect.animate .bottom-btn-icon {
  animation: collectPop 0.35s ease-out;
}
/* 宝宝喜欢：激活 #FF6B6B + 点击时心跳动画 */
.bottom-btn.like.active .bottom-btn-text { color: #FF6B6B; }
.bottom-btn.like.active .bottom-btn-icon {
  filter: brightness(0) saturate(100%) invert(58%) sepia(98%) saturate(2476%) hue-rotate(346deg) brightness(101%) contrast(101%);
}
.bottom-btn.like.heart-beat .bottom-btn-icon {
  animation: heartBeat 0.2s ease-out;
}
@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
/* 不爱吃：激活 #F6A65A（filled + 橙琥珀色） */
.bottom-btn.dislike.active .bottom-btn-text { color: #F6A65A; }
.bottom-btn.dislike.active .bottom-btn-icon {
  filter: brightness(0) saturate(100%) invert(78%) sepia(55%) saturate(1200%) hue-rotate(360deg) brightness(102%) contrast(95%);
}
/* 换一个：常显 #6EBF85（操作按钮，非切换） */
.bottom-btn.change .bottom-btn-text { color: #6EBF85; }
.bottom-btn.change .bottom-btn-icon {
  filter: brightness(0) saturate(100%) invert(72%) sepia(42%) saturate(800%) hue-rotate(100deg) brightness(95%) contrast(90%);
}
.bottom-btn.change .bottom-btn-icon.icon-rotating {
  animation: rotate360 0.3s ease-out;
}
@keyframes collectPop {
  0% { transform: scale(0.9); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}
@keyframes rotate360 {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ========== 加载 / 空态 ========== */
.loading-wrap, .empty-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
  padding: 32rpx;
  background: #F7F9F8;
}
.loading-text, .empty-text {
  font-size: 28rpx;
  color: #7A8B83;
}
