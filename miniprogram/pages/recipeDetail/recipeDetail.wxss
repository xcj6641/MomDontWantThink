/* ========== 与本周计划页统一：页面背景 + 卡片层级 ========== */
.page {
  min-height: 100vh;
  background: var(--bg-warm);
  padding-bottom: 160rpx;
  box-sizing: border-box;
}
.page-content {
  padding: 24rpx 24rpx 40rpx;
}

/* ========== 通用卡片：白卡 / 浅色卡，与本周计划页一致 ========== */
.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 40rpx;
  border: 2rpx solid var(--border-warm);
  box-shadow: 0 6rpx 20rpx rgba(127, 183, 126, 0.07);
  box-sizing: border-box;
}

/* ========== 1. 顶部菜谱信息卡：与「本周辅食准备好啦」同系浅绿 ========== */
.recipe-hero {
  background: linear-gradient(165deg, #fbfdf9 0%, #eef6f1 100%);
  border: 2rpx solid rgba(160, 216, 192, 0.4);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}
.recipe-hero-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}
.recipe-hero-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #2F5E3B;
  line-height: 1.35;
}
.recipe-hero-collect {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.recipe-hero-collect .collect-icon {
  width: 36rpx;
  height: 36rpx;
}
.recipe-hero-collect.animate .collect-icon {
  animation: collectPop 0.35s ease-out;
}
@keyframes collectPop {
  0% { transform: scale(0.9); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}
.recipe-hero-tags {
  display: block;
  margin-bottom: 12rpx;
}
.recipe-hero-tag {
  background: rgba(255, 255, 255, 0.85);
  color: #5A7A65;
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  display: inline-block;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  border: 2rpx solid #E3EFE7;
}
.recipe-hero-desc {
  font-size: 26rpx;
  color: #7A8A7E;
  line-height: 1.6;
  display: block;
}

/* ========== 2. 备菜小提醒：与食材、做法一致的白卡 ========== */
.card-prep {
  /* 沿用 .card 白底 + 边框 + 阴影 */
}
.prep-main-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #EEF2F0;
}
.prep-main-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2F3A35;
}
.prep-group {
  margin-top: 24rpx;
}
.prep-group:first-of-type {
  margin-top: 0;
}
.prep-group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2F3A35;
  margin-bottom: 12rpx;
  display: block;
}
.prep-item {
  font-size: 26rpx;
  color: #5F6F66;
  line-height: 44rpx;
  margin-bottom: 8rpx;
  padding-left: 0;
}
.prep-item:last-child {
  margin-bottom: 0;
}

/* ========== 模块标题：食材 / 做法 / 小提示 ========== */
.card-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}
.card-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2F3A35;
}
.card-title-border {
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid #EEF2F0;
}

/* ========== 3. 食材卡片：极浅暖白，绿灰字 ========== */
.ingredient-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  font-size: 26rpx;
}
.ingredient-name {
  color: #3D5C48;
  font-weight: 500;
}
.ingredient-amount {
  color: #7A8A7E;
  margin-left: 16rpx;
}

/* ========== 4. 做法卡片：柔和绿编号 + 深灰绿正文 ========== */
.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}
.step-item:last-child {
  margin-bottom: 0;
}
.step-num {
  color: #5A8A6A;
  font-weight: 600;
  font-size: 28rpx;
  min-width: 44rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}
.step-content {
  font-size: 26rpx;
  color: #2F3A35;
  line-height: 46rpx;
  flex: 1;
}

/* ========== 小提示 ========== */
.tip-item {
  font-size: 26rpx;
  color: #5F6F66;
  line-height: 44rpx;
  margin-bottom: 10rpx;
  display: block;
}
.tip-item:last-child {
  margin-bottom: 0;
}

/* ========== 底部固定操作栏 ========== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 128rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #FFFFFF;
  border-top: 2rpx solid #EEF2F0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex: 1;
  background: transparent;
  font-size: 20rpx;
}
.bottom-btn-text {
  line-height: 1.2;
  color: #7A8A7E;
}
.bottom-btn-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) saturate(100%) invert(72%) sepia(22%) saturate(800%) hue-rotate(110deg) brightness(92%) contrast(88%);
}
.bottom-btn.collect.active .bottom-btn-text { color: #F6B73C; }
.bottom-btn.collect.active .bottom-btn-icon {
  filter: brightness(0) saturate(100%) invert(82%) sepia(45%) saturate(1500%) hue-rotate(360deg) brightness(102%) contrast(95%);
}
.bottom-btn.like.active .bottom-btn-text { color: #FF6B6B; }
.bottom-btn.like.active .bottom-btn-icon {
  filter: brightness(0) saturate(100%) invert(58%) sepia(98%) saturate(2476%) hue-rotate(346deg) brightness(101%) contrast(101%);
}
.bottom-btn.like.heart-beat .bottom-btn-icon {
  animation: heartBeat 0.2s ease-out;
}
@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
.bottom-btn.dislike.active .bottom-btn-text { color: #F6A65A; }
.bottom-btn.dislike.active .bottom-btn-icon {
  filter: brightness(0) saturate(100%) invert(78%) sepia(55%) saturate(1200%) hue-rotate(360deg) brightness(102%) contrast(95%);
}
.bottom-btn.change .bottom-btn-text { color: #6EBF85; }
.bottom-btn.change .bottom-btn-icon {
  filter: brightness(0) saturate(100%) invert(72%) sepia(42%) saturate(800%) hue-rotate(100deg) brightness(95%) contrast(90%);
}
.bottom-btn.change .bottom-btn-icon.icon-rotating {
  animation: rotate360 0.3s ease-out;
}
@keyframes rotate360 {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ========== 加载 / 空态 ========== */
.loading-wrap, .empty-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
  padding: 32rpx;
  background: var(--bg-warm);
}
.loading-text, .empty-text {
  font-size: 28rpx;
  color: #7A8A7E;
}
