.container {
  padding-bottom: 60rpx;
}
.container-onboarding {
  min-height: 100vh;
  background: var(--bg-warm);
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.header {
  padding: 32rpx 0;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
}

.today-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(127, 183, 126, 0.07);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--green);
  margin-bottom: 20rpx;
}

.meal-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meal-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-warm);
}

.meal-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.btn-done {
  margin-left: 16rpx;
  font-size: 24rpx;
}

.meal-item:last-child {
  border-bottom: none;
}

.meal-label {
  width: 120rpx;
  flex-shrink: 0;
  color: #4a5c4e;
  font-size: 26rpx;
  font-weight: 600;
}

.meal-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.blw-tag {
  font-size: 22rpx;
  color: var(--green-deep);
  background: rgba(160, 216, 192, 0.22);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.empty-tip {
  padding: 48rpx 0;
  text-align: center;
}

.empty-tip .tip-text {
  display: block;
  margin-bottom: 24rpx;
}

.btn-generate-plan {
  display: inline-block;
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, var(--green) 0%, var(--green-deep) 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.tomorrow-tip {
  padding: 20rpx 0;
  margin-bottom: 24rpx;
}

.next-week-entry {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: linear-gradient(160deg, #fbfdf9 0%, #f0f7f3 100%);
  border-radius: 12rpx;
  border: 1rpx solid rgba(160, 216, 192, 0.35);
}

.next-week-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.next-week-entry .action-btn {
  margin-bottom: 0;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #fff;
  border-radius: 12rpx;
  color: var(--green-deep);
  font-size: 30rpx;
}

.action-btn:active {
  background: var(--fill-warm);
}

/* ========== 初始界面 onboarding：与本周计划页统一设计语言 ========== */
.onboarding {
  padding-bottom: 0;
}
/* 顶部欢迎区：与本周计划页一致 */
.welcome-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: linear-gradient(165deg, #fbfdf9 0%, #eef6f1 100%);
  border: 2rpx solid rgba(160, 216, 192, 0.4);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}
.welcome-card-icon {
  font-size: 44rpx;
  line-height: 1;
  flex-shrink: 0;
}
.welcome-card-body {
  flex: 1;
  min-width: 0;
}
.welcome-card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #2F5E3B;
  margin-bottom: 8rpx;
}
.welcome-card-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.45;
}
/* 表单卡片：白底 + 轻边框 + 轻阴影 */
.form-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 28rpx 28rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid var(--border-warm);
  box-shadow: 0 6rpx 18rpx rgba(127, 183, 126, 0.06);
  box-sizing: border-box;
}
.form-card-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.form-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2F3A35;
}
.form-card-required {
  font-size: 20rpx;
  color: var(--text-muted);
  background: var(--fill-warm);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}
.form-card-optional {
  font-size: 20rpx;
  color: var(--text-muted);
  background: var(--fill-warm);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}
.form-card-hint {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 14rpx;
}
/* 宝宝生日：可点击选择器样式 */
.picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  background: var(--fill-warm);
  border-radius: 20rpx;
  border: 2rpx solid rgba(160, 216, 192, 0.28);
}
.picker-trigger:active {
  opacity: 0.9;
}
.picker-text {
  font-size: 28rpx;
  color: #2F3A35;
}
.picker-text.placeholder {
  color: var(--text-muted);
}
.picker-arrow {
  font-size: 32rpx;
  color: #9daa9f;
  line-height: 1;
}
/* 过敏食材标签 */
.allergen-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.allergen-chip {
  display: inline-flex;
  align-items: center;
  background: rgba(160, 216, 192, 0.22);
  color: var(--green-deep);
  padding: 12rpx 16rpx 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}
.allergen-chip-text {
  margin-right: 8rpx;
}
.allergen-chip-remove {
  font-size: 28rpx;
  line-height: 1;
  color: var(--green-deep);
  opacity: 0.75;
  padding: 0 4rpx;
}
.allergen-chip-remove:active {
  opacity: 1;
}
/* 添加过敏食材：次级按钮，非虚线 */
.btn-add-allergen {
  font-size: 28rpx;
  color: var(--green-deep);
  background: rgba(160, 216, 192, 0.22);
  border: none;
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  line-height: 1.4;
}
.btn-add-allergen::after {
  border: none;
}
.btn-add-allergen:active {
  opacity: 0.9;
}
/* 底部固定区 + 主 CTA */
.bottom-placeholder {
  height: 1rpx;
}
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -2rpx 16rpx rgba(127, 183, 126, 0.09);
  z-index: 10;
}
.btn-primary-cta {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
  background: linear-gradient(135deg, var(--green) 0%, var(--green-deep) 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}
.btn-primary-cta::after {
  border: none;
}
.btn-primary-cta:active {
  opacity: 0.88;
}
.btn-primary-cta[disabled] {
  background: #dce5e0;
  color: var(--text-muted);
}
