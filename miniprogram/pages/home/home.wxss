.container {
  padding-bottom: 60rpx;
}

.header {
  padding: 32rpx 0;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
}

.today-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #07c160;
  margin-bottom: 20rpx;
}

.meal-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meal-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.meal-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.btn-done {
  margin-left: 16rpx;
  font-size: 24rpx;
}

.meal-item:last-child {
  border-bottom: none;
}

.meal-label {
  width: 120rpx;
  color: #666;
  font-size: 26rpx;
}

.meal-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.blw-tag {
  font-size: 22rpx;
  color: #07c160;
  background: #e8f8f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.empty-tip {
  padding: 48rpx 0;
  text-align: center;
}

.empty-tip .tip-text {
  display: block;
  margin-bottom: 24rpx;
}

.btn-generate-plan {
  display: inline-block;
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.tomorrow-tip {
  padding: 20rpx 0;
  margin-bottom: 24rpx;
}

.next-week-entry {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #f8fcf9;
  border-radius: 12rpx;
  border: 1rpx solid #e0f0e8;
}

.next-week-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.next-week-entry .action-btn {
  margin-bottom: 0;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #fff;
  border-radius: 12rpx;
  color: #07c160;
  font-size: 30rpx;
}

.action-btn:active {
  background: #f5f5f5;
}

/* 初始界面 onboarding */
.onboarding {
  padding-bottom: 140rpx;
}
.welcome {
  padding: 32rpx 0 40rpx;
}
.welcome-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.welcome-subtitle {
  display: block;
  font-size: 26rpx;
  color: #666;
}
.onboarding .card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.onboarding .card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}
.picker-display {
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #333;
}
.card-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}
.allergen-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.chip {
  display: inline-flex;
  align-items: center;
  background: #e8f8f0;
  color: #07c160;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
}
.chip-text { margin-right: 8rpx; }
.chip-remove {
  font-size: 32rpx;
  line-height: 1;
  opacity: 0.8;
}
.btn-add-allergen {
  font-size: 28rpx;
  color: #07c160;
  background: transparent;
  border: 1rpx dashed #07c160;
  border-radius: 12rpx;
  padding: 20rpx;
}
.bottom-placeholder { height: 1rpx; }
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.btn-primary-bottom {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}
.btn-primary-bottom[disabled] {
  background: #ccc;
  color: #999;
}
