<view class="container {{showInitial ? 'container-onboarding' : ''}}">
  <!-- 初始界面：与本周计划页统一的视觉语言 -->
  <block wx:if="{{showInitial}}">
    <view class="onboarding">
      <view class="welcome-card">
        <view class="welcome-card-icon">🌱</view>
        <view class="welcome-card-body">
          <text class="welcome-card-title">我来帮你安排宝宝辅食</text>
          <text class="welcome-card-subtitle">先填写宝宝生日，我就能按月龄生成适合的本周辅食计划</text>
        </view>
      </view>

      <view class="form-card birthday-card">
        <view class="form-card-head">
          <text class="form-card-title">宝宝生日</text>
          <text class="form-card-required">必填</text>
        </view>
        <picker mode="date" value="{{babyBirthday}}" start="2020-01-01" end="2030-12-31" bindchange="onBirthdayChange">
          <view class="picker-trigger">
            <text class="picker-text {{babyBirthday ? '' : 'placeholder'}}">{{babyBirthday || '请选择日期'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
        <text class="form-card-hint">我会根据生日自动计算月龄</text>
      </view>

      <view class="form-card allergens-card">
        <view class="form-card-head">
          <text class="form-card-title">过敏食材</text>
          <text class="form-card-optional">可选</text>
        </view>
        <view class="allergen-chips" wx:if="{{allergens.length > 0}}">
          <view class="allergen-chip" wx:for="{{allergens}}" wx:key="*this">
            <text class="allergen-chip-text">{{item}}</text>
            <text class="allergen-chip-remove" data-index="{{index}}" catchtap="onRemoveAllergen">×</text>
          </view>
        </view>
        <button class="btn-add-allergen" bindtap="onAddAllergen">+ 添加过敏食材</button>
        <text class="form-card-hint">可先不填，之后也能随时补充</text>
      </view>

      <view class="bottom-placeholder"></view>
      <view class="bottom-bar">
        <button class="btn-primary-cta" disabled="{{!birthdayValid || generating}}" loading="{{generating}}" bindtap="onGenerateThisWeek">生成本周辅食计划</button>
      </view>
    </view>
  </block>

  <!-- 常规界面 -->
  <block wx:else>
    <view class="header">
      <text class="title">✔️ 已帮你准备好今日安排</text>
      <text class="subtitle tip-text">👉 记得提前解冻食材哦</text>
    </view>

    <view class="today-card" wx:if="{{todayMeals.length > 0}}">
      <view class="card-title">今日菜单 · {{today}}</view>
      <view class="meal-list">
        <view class="meal-item" wx:for="{{todayMeals}}" wx:key="mealKey">
          <view class="meal-info">
            <text class="meal-label">{{item.mealLabel || item.mealKey}}</text>
            <text class="meal-name">{{item.recipeName || '未安排'}}</text>
            <text class="blw-tag" wx:if="{{item.blw}}">BLW</text>
          </view>
          <button class="btn-done" size="mini" data-mealkey="{{item.mealKey}}" data-date="{{today}}" data-recipeid="{{item.recipeId}}" data-recipename="{{item.recipeName}}" bindtap="onMarkDone">✔ 标记已做</button>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:else>
      <text class="tip-text">还没有本周计划</text>
      <navigator url="/pages/week/week?weekStartDate={{thisWeekStartDate}}&needConfirm=1&babyBirthday={{babyBirthday}}" class="btn-generate-plan">生成本周计划</navigator>
    </view>

    <view class="tomorrow-tip tip-text" wx:if="{{tomorrowTip}}">
      {{tomorrowTip}}
    </view>

    <view class="next-week-entry" wx:if="{{nextWeekStartDate}}">
      <text class="next-week-label" wx:if="{{nextWeekStatus === 'generated'}}">🌿 下周计划已准备</text>
      <text class="next-week-label" wx:else>下周计划</text>
      <navigator wx:if="{{nextWeekStatus === 'generated'}}" url="/pages/week/week?weekStartDate={{nextWeekStartDate}}&babyBirthday={{babyBirthday}}" class="action-btn">查看下周计划</navigator>
      <navigator wx:else url="/pages/week/week?weekStartDate={{nextWeekStartDate}}&needConfirm=1&babyBirthday={{babyBirthday}}" class="action-btn">生成下周计划</navigator>
    </view>

    <view class="actions">
      <navigator url="/pages/todayFood/todayFood" open-type="switchTab" class="action-btn">今日辅食</navigator>
      <navigator url="/pages/week/week" class="action-btn">本周计划</navigator>
      <navigator url="/pages/shopping/shopping" class="action-btn">购物清单</navigator>
    </view>
  </block>
</view>
