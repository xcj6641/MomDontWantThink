/* pages/weekSummary/weekSummary.wxss */

page {
  background: #F6FBF7;
}

.container {
  min-height: 100vh;
  padding: 0 0 40rpx;
}

/* ── 1. 头部信息区（遵循头部信息区设计风格规范） ── */
.info-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: linear-gradient(165deg, #fbfdf9 0%, #eef6f1 100%);
  border: 2rpx solid rgba(160, 216, 192, 0.40);
  border-radius: 32rpx;
  padding: 32rpx;
  margin: 24rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.info-card-icon {
  font-size: 44rpx;
  line-height: 1;
  flex-shrink: 0;
}

.info-card-body {
  flex: 1;
  min-width: 0;
}

.info-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.info-card-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #2f5e3b;
}

.info-card-subtitle {
  display: block;
  font-size: 26rpx;
  color: #6e7b70;
  line-height: 1.45;
}

.info-card-actions {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.info-card-link {
  font-size: 24rpx;
  font-weight: 500;
  color: #6ba86a;
  border-bottom: 1rpx solid rgba(107, 168, 106, 0.45);
  padding-bottom: 2rpx;
  line-height: 1.35;
}

.info-card-link:active {
  opacity: 0.55;
}

.fav-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-width: 184rpx; /* lock to wider state (已收藏周计划): 32+6+144rpx, prevents icon shift on toggle */
}

.fav-btn:active {
  opacity: 0.55;
}

.fav-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.fav-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #6ba86a;
  line-height: 1.35;
}

/* ── 2. Progress ── */
.progress-card {
  margin: 0 24rpx 24rpx;
  background: #EAF6EC;
  border-radius: 32rpx;
  padding: 28rpx 28rpx 24rpx;
}

.progress-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-label {
  font-size: 28rpx;
  color: #2d4a34;
  font-weight: 500;
}

.progress-pct {
  font-size: 30rpx;
  color: #2d6e37;
  font-weight: 700;
}

.progress-track {
  position: relative;
  height: 20rpx;
  background: #C8E6CA;
  border-radius: 10rpx;
  overflow: visible;
}

.progress-fill {
  height: 100%;
  background: #7FB77E;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bear {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 32rpx;
  line-height: 1;
  pointer-events: none;
}

/* ── Section titles ── */
.section-title {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: 600;
  color: #2d4a34;
  padding: 8rpx 32rpx 16rpx;
}

.section-title-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-icon {
  font-size: 32rpx;
  line-height: 1;
}

.section-hint {
  font-size: 24rpx;
  font-weight: 400;
  color: #9aae9c;
  margin-left: 4rpx;
}

.section-title-action {
  font-size: 24rpx;
  font-weight: 400;
  color: #7FB77E;
}

/* ── 3 & 4. Shared card + row styles ── */
.category-card {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.category-header {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx 16rpx;
  border-bottom: 1rpx solid #F0F5F1;
}

.category-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.category-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d4a34;
}

.ingredient-row {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid #F7FAF8;
}

.ingredient-row:last-child {
  border-bottom: none;
}

.row--done {
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #C5D8C7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #fff;
}

.checkbox--checked {
  background: #7FB77E;
  border-color: #7FB77E;
}

.checkbox-mark {
  font-size: 24rpx;
  color: #fff;
  line-height: 1;
}

.row-main {
  flex: 1;
  font-size: 28rpx;
  color: #2d4a34;
}

.row--done .row-main {
  color: #8fbe8e;
}

.row-sub {
  font-size: 26rpx;
  color: #9aae9c;
  margin-left: 12rpx;
}

/* ── 4. Prep task expand ── */
.used-in-row {
  display: flex;
  align-items: center;
  padding: 8rpx 28rpx 16rpx 88rpx;
}

.used-in-text {
  font-size: 24rpx;
  color: #7FB77E;
  line-height: 1;
}

/* ── CSS chevron arrows (no text character, no alignment issues) ── */
.chevron-sm {
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid #7FB77E;
  border-bottom: 3rpx solid #7FB77E;
  border-radius: 1rpx;
  transform: rotate(45deg);
  transition: transform 0.25s ease;
  flex-shrink: 0;
  margin-left: 10rpx;
}

.chevron-md {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #9dc49c;
  border-bottom: 3rpx solid #9dc49c;
  border-radius: 1rpx;
  transform: rotate(45deg);
  transition: transform 0.25s ease;
  flex-shrink: 0;
}

.chevron--open {
  transform: rotate(225deg);
}

.dishes-expanded {
  padding: 4rpx 28rpx 16rpx 88rpx;
  background: #F6FBF7;
}

.dish-item {
  display: block;
  font-size: 24rpx;
  color: #7a9480;
  line-height: 1.8;
}

.row-divider {
  height: 1rpx;
  background: #F0F5F1;
  margin: 0 28rpx;
}

/* ── 5. Accordion ── */
.accordion-card {
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.accordion-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
}

.accordion-header-left {
  display: flex;
  flex-direction: column;
}

.accordion-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d4a34;
}

.accordion-weekdays {
  font-size: 24rpx;
  color: #7a9480;
  margin-top: 4rpx;
}

.accordion-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.accordion-summary {
  font-size: 24rpx;
  color: #9aae9c;
}


.accordion-body {
  border-top: 1rpx solid #F0F5F1;
  padding: 20rpx 28rpx 24rpx;
  background: #FAFCFA;
}


.meal-group {
  margin-bottom: 24rpx;
}

.meal-group:last-child {
  margin-bottom: 0;
}

.meal-group-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2d4a34;
  margin-bottom: 10rpx;
}

.meal-group-dish {
  display: block;
  font-size: 28rpx;
  color: #4a6b52;
  line-height: 1.7;
  margin-bottom: 6rpx;
}

.meal-group-dish:last-child {
  margin-bottom: 0;
}

/* ── Empty ── */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #7a9480;
  margin-bottom: 12rpx;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #aabdac;
}

/* ── Footer ── */
.footer-placeholder {
  height: 40rpx;
}
