/* 与首页初始页 welcome-card 同色底，白卡片浮在浅绿上 */
.container {
  min-height: 100vh;
  box-sizing: border-box;
  background: #eaf7ef;
  padding: 24rpx 24rpx 200rpx;
}

.tip {
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #6e7b70;
  line-height: 1.45;
}

.block {
  margin-bottom: 28rpx;
}

.block-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.block-hint {
  display: block;
  font-size: 24rpx;
  color: #8a978e;
  margin-top: 8rpx;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.footer-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #7fb77e 0%, #6ba86a 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
}
