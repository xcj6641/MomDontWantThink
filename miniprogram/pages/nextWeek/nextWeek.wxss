.container { }

.tip {
  padding: 20rpx 0;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
}

.top-bar {
  margin-bottom: 24rpx;
  text-align: right;
}

.link-shopping {
  font-size: 28rpx;
  color: #07c160;
}

.success-block {
  background: #f0f9f4;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid #e0f0e8;
}

.success-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #07c160;
  margin-bottom: 12rpx;
}

.success-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.success-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.success-actions .btn-primary,
.success-actions .btn-secondary {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
}

.btn-secondary {
  background: #fff;
  color: #07c160;
  border: 2rpx solid #07c160;
}

.reminder {
  display: block;
}

.generate-block {
  margin-bottom: 28rpx;
}

.generate-block .tip-text {
  display: block;
  margin-top: 12rpx;
}

.this-week-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.this-week-section .section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.this-week-section .tip-text {
  display: block;
  margin-bottom: 20rpx;
}

.this-week-section .btn-generate {
  width: 100%;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.btn-generate {
  padding: 16rpx 28rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.day-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.day-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.day-date {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #07c160;
  margin-bottom: 16rpx;
}

.meal-row {
  display: flex;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.meal-k {
  width: 100rpx;
  color: #666;
}

.meal-v {
  flex: 1;
  color: #333;
}

.empty {
  padding: 48rpx 0;
  text-align: center;
}
