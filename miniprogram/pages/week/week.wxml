<view class="container">
  <view class="debug-fab" bindtap="onToggleWeekDebugPanel">调试视图</view>
  <view class="debug-panel" wx:if="{{weekDebugPanelVisible}}">
    <text class="debug-panel-title">计划页调试模式</text>
    <view class="debug-mode-item {{weekDebugViewMode === 'auto' ? 'active' : ''}}" data-mode="auto" bindtap="onSelectWeekDebugMode">自动（跟数据）</view>
    <view class="debug-mode-item {{weekDebugViewMode === 'regular' ? 'active' : ''}}" data-mode="regular" bindtap="onSelectWeekDebugMode">强制常规页</view>
    <view class="debug-mode-item {{weekDebugViewMode === 'exception' ? 'active' : ''}}" data-mode="exception" bindtap="onSelectWeekDebugMode">强制异常页</view>
  </view>

  <!-- 顶部状态提示卡片：独立信息卡，左侧图标 -->
  <view class="welcome-card">
    <view class="welcome-card-icon">🌱</view>
    <view class="welcome-card-body">
      <text class="welcome-title" wx:if="{{babyAgeMonths != null && babyAgeMonths < 5}}">宝宝未满5个月，当前不推荐生成辅食备餐计划</text>
      <text class="welcome-title" wx:elif="{{isNextWeek}}">下周辅食准备好啦</text>
      <text class="welcome-title" wx:else>本周辅食准备好啦</text>
      <text class="welcome-subtitle" wx:if="{{babyAgeMonths != null && babyAgeMonths < 5}}">宝宝{{babyAgeMonths}}月龄，可以先了解备餐计划的使用方式</text>
      <text class="welcome-subtitle" wx:elif="{{babyAgeMonths != null && babyAgeMonths >= 5}}">根据宝宝{{babyAgeMonths}}月龄生成，可以随时调整</text>
    </view>
  </view>

  <!-- 加载态 -->
  <view class="loading-block" wx:if="{{weekDebugShowLoading}}">
    <text class="loading-text">{{isNextWeek ? '正在帮你生成下周计划…' : '正在帮你生成本周计划…'}}</text>
    <view class="skeleton-list">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
    </view>
  </view>

  <!-- 与常规页同一套布局；无备餐数据时「备餐安排」下为异常重试区 -->
  <block wx:else>
    <view class="date-district-card">
      <view class="date-district-title-row">
        <text class="date-district-prep-title">本周备 {{settingsNVal || 3}} 套备餐</text>
        <text class="date-district-adjust" catchtap="onOpenMenuCountModal">调整</text>
      </view>
      <view class="date-district-summary-row">
        <text class="date-district-label">日期分配</text>
        <text class="date-district-tag">{{settingsDistributionText}}</text>
      </view>
      <view class="prep-buttons">
        <view
          class="prep-btn {{settingsSelectedIndex === item + 1 ? 'active' : ''}}"
          wx:for="{{settingsTabList}}"
          wx:key="*this"
          data-index="{{item}}"
          bindtap="onSettingsTabTap"
        >
          <view class="prep-btn-dot" style="background-color: {{settingsTemplateColors[item]}};"></view>
          <text>备餐{{item + 1}}</text>
        </view>
      </view>
      <view class="week-days-row">
        <view
          class="week-day-cell {{item.isUnassigned ? 'unassigned' : ''}} {{item.isCurrent ? 'current' : 'assigned'}}"
          style="{{item.bgStyle}}"
          wx:for="{{settingsDayCellList}}"
          wx:key="day"
          data-day="{{item.day}}"
          bindtap="onSettingsDayTap"
        >
          <text class="week-day-label">{{item.shortLabel}}</text>
        </view>
      </view>
    </view>

    <!-- 分组标题：备餐安排 -->
    <view class="section-title-wrap">
      <text class="section-title-icon">🥣</text>
      <text class="section-title-text">备餐安排</text>
    </view>

    <block wx:if="{{weekPlanListForRender.length > 0}}">
      <view class="template-cards">
        <view
          class="template-card {{item.isPlaceholder ? 'placeholder' : ''}}"
          wx:for="{{weekPlanListForRender}}"
          wx:for-index="cardIndex"
          wx:key="templateName"
          data-prep-id="{{item.templateId}}"
          bindtap="onCardTap"
        >
          <view class="template-card-accent" style="background: {{settingsTemplateColors[cardIndex] || '#7FB77E'}};"></view>
          <!-- 头部：备餐名 + 三点菜单，下方日期（保持原设计） -->
          <view class="template-card-header" style="background: {{settingsTemplateBgColors[cardIndex] || '#F2F4F5'}};">
            <view class="template-header-inner">
              <view class="template-dot" style="background: {{settingsTemplateColors[cardIndex]}}"></view>
              <text class="template-name">{{item.templateName}}</text>
              <view class="template-card-menu" catchtap="onCardMenuTap" data-index="{{cardIndex}}" data-template-id="{{item.templateId}}" data-is-placeholder="{{item.isPlaceholder}}">⋯</view>
            </view>
            <view class="template-dates-chips">
              <text class="date-chip" wx:for="{{item.dateChips}}" wx:key="date" data-date="{{item.date}}" data-prep-id="{{item.templateId}}" bindtap="onTapDate">{{item.weekdayLabel}}</text>
            </view>
          </view>
          <!-- 日期区与菜单区之间淡分隔线 -->
          <view class="template-card-divider"></view>
          <!-- 菜单区：左列餐次名 + BLW 小标签（固定宽），右列菜名；BLW 随当前卡片 cardIndex 取色 -->
          <view class="template-card-meals">
            <view class="meal-row" wx:for="{{item.meals}}" wx:for-item="meal" wx:key="mealKey">
              <view
                class="meal-slot-cell"
                catchtap="onMealSlotTap"
                data-template-id="{{item.templateId}}"
                data-card-index="{{cardIndex}}"
                data-is-placeholder="{{item.isPlaceholder}}"
              >
                <text class="meal-slot">{{meal.mealLabel}}</text>
                <text
                  class="meal-blw-tag"
                  wx:if="{{meal.blw}}"
                  style="color: {{settingsTemplateColors[cardIndex]}}; background: {{settingsTemplateBgColors[cardIndex]}};"
                >BLW</text>
              </view>
              <text
                class="meal-recipe meal-name-clamp"
                data-recipe-id="{{item.recipeId}}"
                catchtap="onRecipeNameTap"
              >{{meal.hasOverride ? '✎ ' : ''}}{{meal.recipeName || '未安排'}}{{meal.overrideSuffix ? ' | ' + meal.overrideSuffix : ''}}</text>
            </view>
          </view>
          <text wx:if="{{item.isPlaceholder}}" class="placeholder-hint">保存后生成菜单</text>
        </view>
      </view>
      <!-- 与备餐卡片同分支：只要当前展示的是备餐列表（含 Mock/云端），底部即显示确认 -->
      <view class="confirm-area">
        <button class="btn-confirm-week" bindtap="onConfirmWeek">{{isNextWeek ? '确认并开始下周计划' : '确认并开始本周计划'}}</button>
        <text class="confirm-hint">确认后回到「今天安排」，之后也能随时调整</text>
      </view>
    </block>

    <view class="plan-empty-retry" wx:else>
      <text class="plan-empty-retry-line">
        数据异常 <text class="plan-empty-retry-link {{planRetryLoading ? 'is-disabled' : ''}}" catchtap="onRetryFetchPlanData">点击重试</text>
      </text>
      <view class="plan-retry-loading" wx:if="{{planRetryLoading}}">
        <view class="plan-retry-spin"></view>
        <text class="plan-retry-loading-text">加载中…</text>
      </view>
    </view>

    <!-- 分配日期弹框（Mock 下点击日期区域打开，回显当前分配） -->
    <view class="menu-count-modal-mask" wx:if="{{showAssignDateModal}}" catchtap="onCloseAssignDateModal"></view>
    <view class="menu-count-modal-panel" wx:if="{{showAssignDateModal}}">
      <view class="menu-count-modal-title">分配日期</view>
      <view class="date-assign-modal-content">
        <text>当前分配：{{assignDateLabels || '—'}}</text>
      </view>
      <button class="menu-count-save-btn" bindtap="onCloseAssignDateModal">关闭</button>
    </view>

    <!-- 备餐套数弹框：内含 1-7 选择 + 保存 -->
    <view class="menu-count-modal-mask" wx:if="{{showMenuCountModal}}" catchtap="onCloseMenuCountModal"></view>
    <view class="menu-count-modal-panel" wx:if="{{showMenuCountModal}}">
      <view class="menu-count-modal-title">{{isNextWeek ? '下周' : '本周'}}准备几套备餐？</view>
      <view class="menu-count-options">
        <view
          class="menu-count-opt {{settingsNVal === item ? 'selected' : ''}}"
          wx:for="{{[1,2,3,4,5,6,7]}}"
          wx:key="*this"
          data-n="{{item}}"
          bindtap="onSelectMenuCountInModal"
        >{{item}} 套</view>
      </view>
      <button class="menu-count-save-btn" bindtap="onSaveSettingsInModal" loading="{{settingsSaving}}">保存</button>
    </view>
  </block>
</view>
