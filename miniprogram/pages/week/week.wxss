/* ========== 整体：页面背景 + 卡片层级 ========== */
.container {
  min-height: 100vh;
  background: var(--bg-warm);
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

/* ========== 顶部状态提示卡片：与页面背景明确区分 ========== */
.welcome-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: linear-gradient(165deg, #fbfdf9 0%, #eef6f1 100%);
  border: 2rpx solid rgba(160, 216, 192, 0.4);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}
.welcome-card-icon {
  font-size: 44rpx;
  line-height: 1;
  flex-shrink: 0;
}
.welcome-card-body {
  flex: 1;
  min-width: 0;
}
.welcome-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #2F5E3B;
  margin-bottom: 8rpx;
}
.welcome-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ========== 加载态 ========== */
.loading-block {
  padding: 20rpx 0;
}
.loading-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.skeleton-card {
  height: 200rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 32rpx;
}

/* ========== 日期分配区：控制面板，与备餐卡片同一设计体系 ========== */
.date-district-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid var(--border-warm);
  box-shadow: 0 6rpx 18rpx rgba(127, 183, 126, 0.06);
}
/* 第一行：标题与操作（左侧本周备x套备餐，右侧调整） */
.date-district-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}
.date-district-prep-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2F3A35;
}
.date-district-adjust {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 2rpx solid var(--border-warm);
}
.date-district-adjust:active {
  opacity: 0.85;
}
/* 第二行：分配摘要（日期分配 + 轻标签） */
.date-district-summary-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}
.date-district-label {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-secondary);
}
.date-district-tag {
  font-size: 22rpx;
  color: #6B7C73;
  background: var(--fill-warm);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}
/* 第三行：备餐1/2/3 按钮组 */
.prep-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.prep-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: var(--fill-warm);
  color: var(--text-secondary);
}
.prep-btn.active {
  background: rgba(160, 216, 192, 0.22);
  color: var(--green-deep);
  font-weight: 600;
}
.prep-btn:active {
  opacity: 0.9;
}
.prep-btn-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
/* 第四行：星期分配（更轻、更精致） */
.week-days-row {
  display: flex;
  flex-wrap: nowrap;
  gap: 10rpx;
}
.week-day-cell {
  flex: 1;
  min-width: 0;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border-radius: 16rpx;
  border: none;
}
.week-day-cell.unassigned {
  background: var(--fill-warm);
  color: var(--text-muted);
}
.week-day-cell:active {
  opacity: 0.9;
}
.week-day-label {
  font-size: 24rpx;
  display: block;
}

/* ========== 分组标题：备餐安排 ========== */
.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}
.section-title-icon {
  font-size: 32rpx;
}
.section-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2F3A35;
}

/* ========== 备餐卡片：统一白底 + 轻边框 + 轻阴影 + 16px 圆角 ========== */
.template-cards {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}
.template-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  border: 2rpx solid var(--border-warm);
  box-shadow: 0 6rpx 20rpx rgba(127, 183, 126, 0.07);
}
.template-card-accent {
  height: 8rpx;
  width: 100%;
  flex-shrink: 0;
}
/* 头部：圆点 + 备餐名 + 三点菜单 */
.template-card-header {
  padding: 16rpx 28rpx 14rpx;
}
.template-header-inner {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.template-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.template-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #2F3A35;
  min-width: 0;
}
.template-card-menu {
  font-size: 26rpx;
  color: #B0B8BC;
  padding: 6rpx 0 6rpx 8rpx;
  flex-shrink: 0;
}
.template-card-menu:active {
  opacity: 0.7;
}
/* 头部星期：白底轻按钮，与浅绿 header 区分；选中为品牌绿 */
.template-dates-chips {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}
.date-chip {
  font-size: 24rpx;
  color: #5F6F67;
  padding: 8rpx 20rpx;
  background: #FFFFFF;
  border: 2rpx solid #E6ECE9;
  border-radius: 20rpx;
}
.date-chip:active {
  background: #7FB77E;
  color: #FFFFFF;
  border-color: #7FB77E;
}
/* 日期区与菜单区之间淡分隔线 */
.template-card-divider {
  height: 0;
  border-top: 2rpx solid #EEF2F0;
  margin: 0 28rpx;
}
/* 菜单区：餐次列固定宽度，菜名左边界统一对齐 */
.template-card-meals {
  padding: 20rpx 28rpx 28rpx;
}
.meal-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  gap: 16rpx;
}
.meal-slot-cell {
  flex-shrink: 0;
  width: 144rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}
.meal-slot {
  font-size: 24rpx;
  color: #7B8794;
  line-height: 1.5;
}
.meal-blw-tag {
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
  line-height: 1.4;
  /* 色值由内联 style 随当前备餐卡片色系注入 */
}
.meal-recipe {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #3C4A45;
  line-height: 1.6;
  word-break: break-word;
}
.meal-name-clamp {
  display: block;
  overflow: visible;
}
.template-card.placeholder .meal-recipe {
  color: #9CA3A8;
}
.placeholder-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #9CA3A8;
  padding: 20rpx 0;
}

/* ========== 底部确认按钮 ========== */
.confirm-area {
  margin-top: 40rpx;
  padding: 0 0 40rpx;
}
.confirm-area .btn-confirm-week {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
  background: linear-gradient(135deg, #7FB77E 0%, #6BA86A 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  border: none;
}
.confirm-area .btn-confirm-week::after {
  border: none;
}
.confirm-area .btn-confirm-week:active {
  opacity: 0.88;
}
.confirm-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #9CA3A8;
  margin-top: 16rpx;
}

/* ========== 弹框 ========== */
.menu-count-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}
.menu-count-modal-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  z-index: 101;
}
.menu-count-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2F3A35;
  margin-bottom: 32rpx;
  text-align: center;
}
.date-assign-modal-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}
.menu-count-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 32rpx;
}
.menu-count-opt {
  width: calc((100% - 60rpx) / 4);
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #2F3A35;
  background: var(--fill-warm);
  border-radius: 20rpx;
}
.menu-count-opt.selected {
  background: #EAF7EF;
  color: #7FB77E;
  font-weight: 600;
}
.menu-count-save-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  background: linear-gradient(135deg, #7FB77E 0%, #6BA86A 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  border: none;
}
.menu-count-save-btn::after {
  border: none;
}

/* ========== 空态 ========== */
.empty {
  padding: 48rpx 0;
  text-align: center;
}
.tip-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}
/* 与 todayFood / home 初始页「生成本周辅食计划」主按钮一致，避免仅改字色导致绿字叠绿底看不见 */
.btn-primary {
  width: 100%;
  box-sizing: border-box;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  line-height: 1.3;
  background: linear-gradient(135deg, var(--green) 0%, var(--green-deep) 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  text-decoration: none;
}
.btn-primary::after {
  border: none;
}
.btn-primary:active {
  opacity: 0.88;
}
.empty .btn-primary--mt {
  margin-top: 24rpx;
}
