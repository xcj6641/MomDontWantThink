.container { }

.tip {
  padding: 20rpx 0;
}

.add-btn {
  display: block;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #7fb77e;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.recipe-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.recipe-item .name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.recipe-item .category {
  font-size: 24rpx;
  color: #8a978e;
}

.empty {
  padding: 48rpx 0;
  text-align: center;
}
