.container { }

.summary-row {
  padding: 24rpx 0;
  margin-bottom: 16rpx;
}

.by-category {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.category-block {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.category-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #7fb77e;
  margin-bottom: 16rpx;
}

.item-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e4ede6;
}

.item-row:last-child {
  border-bottom: none;
}

.item-row.prepared .item-name {
  color: #8a978e;
  text-decoration: line-through;
}

.item-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.item-amount {
  font-size: 24rpx;
  color: #8a978e;
  margin-right: 16rpx;
}

.check {
  font-size: 28rpx;
  color: #7fb77e;
}

.empty {
  padding: 48rpx 0;
  text-align: center;
}
