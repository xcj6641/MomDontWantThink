/**
 * 母婴配色：暖白底、柔绿主色、辅助橙与淡绿
 * 与 page 同级子节点可使用 var(--*)
 */
page {
  --bg-warm: #f7faf8;
  --card: #ffffff;
  --green: #7fb77e;
  --green-deep: #6ba86a;
  --accent-orange: #f4b860;
  --accent-mint: #a0d8c0;
  --text-heading: #2f5e3b;
  --text-body: #2f3a35;
  --text-secondary: #6e7b70;
  --text-muted: #7d8b80;
  --border-warm: #e4ede6;
  --fill-warm: #f0f4f1;
  --shadow-card: 0 12rpx 40rpx rgba(127, 183, 126, 0.07), 0 4rpx 16rpx rgba(90, 120, 95, 0.05);
}
