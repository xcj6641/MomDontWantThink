.meal-item-root {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.meal-item-root:last-child {
  border-bottom: none;
}

.info {
  flex: 1;
  display: flex;
  align-items: center;
}

.meal-label {
  width: 100rpx;
  font-size: 26rpx;
  color: #6e7b70;
}

.meal-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.blw-tag {
  font-size: 22rpx;
  color: #7fb77e;
  background: #e8f8f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: 16rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 0 12rpx;
}
